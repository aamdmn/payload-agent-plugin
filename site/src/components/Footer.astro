---
const repo = "https://github.com/aamdmn/payload-agent";
---

<footer class="mt-24">
	<hr class="border-0 border-t border-hairline" />
	<div
		class="mx-auto flex w-full max-w-[1320px] items-center justify-between px-6 py-7 text-[13px] text-secondary"
	>
		<span class="font-mono tracking-[0.02em]">MIT licensed · payload-agent</span>
		<nav class="flex gap-5">
			<a
				href={repo}
				target="_blank"
				rel="noopener"
				class="transition-colors hover:text-fg">GitHub</a
			>
		</nav>
	</div>
</footer>
