{
  "name": "payload-agent",
  "version": "0.8.0",
  "description": "AI chat agent for Payload CMS - query and manage your content from Telegram, Slack, WhatsApp and more.",
  "keywords": [
    "payload",
    "payload-cms",
    "payloadcms",
    "plugin",
    "ai",
    "agent",
    "chatbot",
    "telegram",
    "slack",
    "whatsapp"
  ],
  "homepage": "https://github.com/aamdmn/payload-agent#readme",
  "bugs": "https://github.com/aamdmn/payload-agent/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aamdmn/payload-agent.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm copyfiles && pnpm build:types && pnpm build:swc && pnpm build:strip-tests",
    "build:strip-tests": "rimraf \"dist/**/*.spec.*\"",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "clean": "rimraf {dist,*.tsbuildinfo}",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "dev": "next dev dev --turbo",
    "dev:generate-importmap": "pnpm dev:payload generate:importmap",
    "dev:generate-types": "pnpm dev:payload generate:types",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:importmap": "pnpm dev:generate-importmap",
    "generate:types": "pnpm dev:generate-types",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "pnpm test:int",
    "test:e2e": "playwright test",
    "test:eval": "cross-env RUN_AGENT_EVALS=1 vitest run --config vitest.eval.config.js",
    "test:int": "vitest run",
    "prepare": "husky",
    "prepublishOnly": "node scripts/ensure-pnpm.mjs && pnpm clean && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@chat-adapter/telegram": "^4.29.0",
    "@payloadcms/db-mongodb": "3.85.0",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/db-sqlite": "3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "@playwright/test": "1.60.0",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.6.0",
    "@tanstack/ai-anthropic": "^0.11.1",
    "@tanstack/ai-client": "^0.14.0",
    "@tanstack/ai-openai": "^0.10.4",
    "@types/node": "22.19.9",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "copyfiles": "2.4.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "husky": "^9.1.7",
    "mongodb-memory-server": "10.1.4",
    "next": "16.2.6",
    "open": "^10.1.0",
    "payload": "3.85.0",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "3.0.2",
    "sharp": "0.34.2",
    "sort-package-json": "^2.10.0",
    "typescript": "5.7.3",
    "ultracite": "7.8.0",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "@chat-adapter/telegram": "^4.29.0",
    "@payloadcms/richtext-lexical": "^3.37.0",
    "@tanstack/ai-anthropic": "^0.11.1",
    "@tanstack/ai-openai": "^0.10.4",
    "payload": "^3.37.0"
  },
  "peerDependenciesMeta": {
    "@chat-adapter/telegram": {
      "optional": true
    },
    "@payloadcms/richtext-lexical": {
      "optional": true
    },
    "@tanstack/ai-anthropic": {
      "optional": true
    },
    "@tanstack/ai-openai": {
      "optional": true
    }
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver",
      "isolated-vm"
    ]
  },
  "registry": "https://registry.npmjs.org/",
  "dependencies": {
    "@chat-adapter/state-memory": "^4.29.0",
    "@tanstack/ai": "0.23.0",
    "@tanstack/ai-code-mode": "0.1.23",
    "@tanstack/ai-isolate-node": "0.1.23",
    "chat": "^4.29.0",
    "zod": "^4.4.3"
  }
}
